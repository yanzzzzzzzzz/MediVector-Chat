# Copy this file to .env and fill in your own values.
# Docker Compose reads .env automatically from this directory.
# app.py also loads .env for local Python runs.

# Required for embeddings and chat.
OPENAI_API_KEY=

# OpenAI settings.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Retrieval settings.
TOP_K=5
REFERENCE_CANDIDATE_LIMIT=20
MAX_REFERENCE_DISTANCE=0.65
REFERENCE_DISTANCE_MARGIN=0.12
MEMORY_MESSAGES=10
MAX_EMBEDDING_CHARS=6000

# Local Python app settings.
HOST=127.0.0.1
PORT=8000

# Local Weaviate settings. Docker overrides these internally for the app container.
WEAVIATE_HOST=127.0.0.1
WEAVIATE_PORT=8080
WEAVIATE_GRPC_PORT=50051

# Local MinIO settings. Docker uses the same access key and secret key for MinIO.
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=health-education-files
MINIO_SECURE=false
